# Copy this file to .env and fill in your values

# --- Option A: Anthropic (works now, no event credits needed) ---
# Get from https://console.anthropic.com → API Keys
ANTHROPIC_API_KEY=your_key_here
PLANNING_BACKEND=claude

# --- Option B: Gemini (needs event credits from Google staff) ---
# GEMINI_API_KEY=your_key_here
# PLANNING_BACKEND=gemini

# --- Executor: who does the in-meeting work (research, dashboards) ---
# "claude"  → local Claude Code subprocess (default; no extra setup, verified)
# "managed" → Gemini Managed Agents, remote Linux sandboxes (needs GEMINI_API_KEY)
EXECUTOR_BACKEND=claude

# Screen capture interval in seconds (default 1.5)
SCREEN_INTERVAL=1.5
