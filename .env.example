# Copy this file to .env and fill in your keys.
# .env holds SECRETS ONLY. Tunable settings (backends, intervals, toggles)
# live in config.toml.

# Required for Gemini planning + Managed Agents executor:
GEMINI_API_KEY=your_key_here

# Optional — only if you set planning.backend = "claude" in config.toml:
# ANTHROPIC_API_KEY=your_key_here
