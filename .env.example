# Copy this file to .env and fill in your values

# Required — get from https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_key_here

# Confirm exact model string at the morning briefing
# Common values: gemini-2.0-flash, gemini-2.5-flash-preview-05-20
GEMINI_MODEL=gemini-2.0-flash

# Screen capture interval in seconds (default 1.5)
SCREEN_INTERVAL=1.5
