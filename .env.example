# Copy this file to .env and fill in your values

# --- Option A: Anthropic (works now, no event credits needed) ---
# Get from https://console.anthropic.com → API Keys
ANTHROPIC_API_KEY=your_key_here
PLANNING_BACKEND=claude

# --- Option B: Gemini (needs event credits from Google staff) ---
# GEMINI_API_KEY=your_key_here
# PLANNING_BACKEND=gemini
# When PLANNING_BACKEND=gemini, in-meeting actionable requests are dispatched to
# pre-defined Gemini Managed Agent specialists (researcher / dashboard-builder /
# doc-checker / generic) running in remote Linux sandboxes. Each run forks a
# fresh sandbox so multiple tasks run truly in parallel.
# Override max time per managed-agent task (default 600s):
# MANAGED_EXECUTOR_TIMEOUT=600

# Screen capture interval in seconds (default 1.5)
SCREEN_INTERVAL=1.5
